// ===== RL Agent Tests (R1-R8) =====

fn test_R1_q_learning() -> bool {
    // Test: Q-learning convergence < 1000 steps
    let agent = create_rl_agent();
    if agent.episode_count == 0 && agent.learning_rate > 0.0 {
        return true;
    }
    return false;
}

fn test_R2_epsilon_greedy() -> bool {
    // Test: Epsilon-greedy action selection
    let agent = create_rl_agent();
    let state = State {
        node_id: "S1",
        entity_type: "TEST",
        context: {},
        feature_vector: []
    };
    let actions = [];
    let action1 = Action {
        type: "test",
        target_node: "T1",
        relation_type: "TEST_REL",
        confidence: 0.8
    };
    push(actions, action1);

    let selected = select_action_epsilon_greedy(agent, state, actions);
    if selected != null {
        return true;
    }
    return false;
}

fn test_R3_policy_gradient() -> bool {
    // Test: Policy gradient initialization
    let policy = create_policy_gradient();
    if length(policy.weights) == 64 && policy.learning_rate > 0.0 {
        return true;
    }
    return false;
}

fn test_R4_value_function() -> bool {
    // Test: Value function approximation
    let vf = create_value_function();
    if length(vf.weights) == 64 {
        return true;
    }
    return false;
}

fn test_R5_softmax() -> bool {
    // Test: Softmax probability distribution
    let logits = [0.1, 0.2, 0.3];
    let probs = softmax(logits);

    if length(probs) == 3 {
        return true;
    }
    return false;
}

fn test_R6_replay_buffer() -> bool {
    // Test: Experience replay buffer
    let buffer = create_replay_buffer(100);
    if buffer.capacity == 100 && length(buffer.experiences) == 0 {
        return true;
    }
    return false;
}

fn test_R7_learning_decay() -> bool {
    // Test: Learning rate decay
    let agent = create_rl_agent();
    let old_rate = agent.learning_rate;
    decay_learning_rate(agent, 0.95);

    if agent.learning_rate < old_rate {
        return true;
    }
    return false;
}

fn test_R8_entropy() -> bool {
    // Test: Entropy calculation
    let probs = [0.5, 0.3, 0.2];
    let entropy = compute_entropy(probs);

    if entropy > 0.0 {
        return true;
    }
    return false;
}

