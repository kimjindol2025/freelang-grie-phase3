fn test_G7_entity_types() -> bool {
    // Test: Multiple entity types recognition
    let recognizer = create_entity_recognizer();
    let text = "John works at Microsoft in New York";
    let entities = recognize_entities(text, recognizer);

    if length(entities) >= 1 {
