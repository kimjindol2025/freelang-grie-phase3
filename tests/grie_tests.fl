    // Test: Pattern matching in relations
    let text = "John Smith located in USA";
    let entities = [];
    let entity1 = Entity {
        id: "E1",
        text: "John",
        type: "PERSON",
        confidence: 0.9,
        start: 0,
        end: 1
    };
    let entity2 = Entity {
        id: "E2",
