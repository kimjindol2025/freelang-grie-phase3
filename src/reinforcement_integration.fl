// Policy Improvement Tracking
fn track_policy_improvement(old_reward: f64, new_reward: f64) -> PolicyImprovement {
    let improvement = PolicyImprovement {
        old_policy_reward: old_reward,
        new_policy_reward: new_reward,
        improvement_percentage: 0.0,
        convergence_rate: 0.0
    };

    if old_reward != 0.0 {
        improvement.improvement_percentage = ((new_reward - old_reward) / old_reward) * 100.0;
    }

    // Convergence rate: target > 5% improvement
    if improvement.improvement_percentage > 5.0 {
        improvement.convergence_rate = (improvement.improvement_percentage / 5.0) * 100.0;
        if improvement.convergence_rate > 100.0 {
            improvement.convergence_rate = 100.0;
        }
    }

    return improvement;
}

fn compute_learning_progress(episode: LearningEpisode) -> f64 {
    if length(episode.rewards) == 0 {
        return 0.0;
    }

    let sum_reward = 0.0;
    let i = 0;
    while i < length(episode.rewards) {
        sum_reward = sum_reward + episode.rewards[i];
        i = i + 1;
    }

    let avg_reward = sum_reward / as_f64(length(episode.rewards));
    return avg_reward;
}

// Multi-Episode Learning
fn run_learning_loop(agent: GRIEAgent, training_texts: array, num_episodes: i32) -> array {
    let episode_results = [];

    let ep = 0;
    while ep < num_episodes {
        let text_idx = ep % length(training_texts);
        let text = training_texts[text_idx];

        let episode = execute_episode(agent, text, 10);
        push(episode_results, episode);

        agent.improvement_rate = compute_avg_improvement(episode_results);

        ep = ep + 1;
    }

    return episode_results;
}

fn compute_avg_improvement(episodes: array) -> f64 {
    if length(episodes) < 2 {
        return 0.0;
    }

    let last_episode = episodes[length(episodes) - 1];
    let prev_episode = episodes[length(episodes) - 2];

    let improvement = track_policy_improvement(prev_episode.episode_reward, last_episode.episode_reward);
    return improvement.improvement_percentage;
}

// Module exports
fn export_integration_module() -> any {
    let module = {};
    module["create_grie_agent"] = "create_grie_agent";
    module["compute_reward"] = "compute_reward";
    module["execute_episode"] = "execute_episode";
    module["run_learning_loop"] = "run_learning_loop";
    module["track_policy_improvement"] = "track_policy_improvement";
    return module;
}
